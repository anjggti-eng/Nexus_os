# ─────────────────────────────────────────────
# NexusOS — Environment Variables
# ─────────────────────────────────────────────

# App
NODE_ENV=development
APP_NAME=NexusOS
API_PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://nexusos:nexusos@postgres:5432/nexusos

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:5672

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=nexusos
MINIO_SECRET_KEY=nexusos_secret
MINIO_BUCKET=nexusos

# ClickHouse
CLICKHOUSE_URL=http://clickhouse:8123

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# WhatsApp
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_MAX_SESSIONS_PER_INSTANCE=10

# OpenAI
OPENAI_API_KEY=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Stripe / Asaas / Mercado Pago
ASAAS_API_KEY=
STRIPE_SECRET_KEY=
MERCADO_PAGO_TOKEN=

# Proxmox
PROXMOX_HOST=
PROXMOX_USER=
PROXMOX_PASSWORD=

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
