{
  "compilerOptions": {
    "module": "commonjs", "declaration": true, "emitDecoratorMetadata": true,
    "experimentalDecorators": true, "target": "ES2022", "sourceMap": true,
    "outDir": "./dist", "rootDir": "./src", "skipLibCheck": true,
    "strictNullChecks": true, "esModuleInterop": true, "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
