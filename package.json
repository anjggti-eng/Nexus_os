{
  "name": "nexusos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "db:generate": "pnpm --filter @nexusos/auth-service db:generate",
    "db:push": "pnpm --filter @nexusos/auth-service db:push",
    "db:migrate": "pnpm --filter @nexusos/auth-service db:migrate",
    "db:seed": "pnpm --filter @nexusos/auth-service db:seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
