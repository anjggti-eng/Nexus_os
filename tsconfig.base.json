{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@nexusos/shared-types": ["packages/shared-types/src"],
      "@nexusos/shared-events": ["packages/shared-events/src"],
      "@nexusos/shared-auth": ["packages/shared-auth/src"],
      "@nexusos/shared-utils": ["packages/shared-utils/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
